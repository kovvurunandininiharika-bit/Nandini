#include <stdio.h>

// Recursive function to calculate factorial
int fact(int n)
{
    if(n == 0 || n == 1)
        return 1;
    else
        return n * fact(n - 1);
}

int main()
{
    int n, r;
    int ncr;

    printf("Enter value of n: ");
    scanf("%d", &n);

    printf("Enter value of r: ");
    scanf("%d", &r);

    if(n > r)
    {
        ncr = fact(n) / (fact(r) * fact(n - r));
        printf("The value of %dC%d = %d\n", n, r, ncr);
    }
    else
    {
        printf("n must be greater than r\n");
    }

    return 0;
}
