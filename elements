#include <stdio.h>

int main()
{
    int arr[5] = {10, 20, 30, 40, 50};
    int *ptr;
    int i;

    ptr = arr;   // pointer pointing to the first element of the array

    printf("Elements of the array using pointer:\n");

    for(i = 0; i < 5; i++)
    {
        printf("%d ", *(ptr + i));   // accessing elements using pointer
    }

    return 0;
}
