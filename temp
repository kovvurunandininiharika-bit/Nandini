    #include <stdio.h>
    int main() 
  {
    float celsius, fahrenheit, cf, fc;

    printf("Enter temperature in Celsius: ");
    scanf("%f", &celsius);

    printf("Enter temperature in Fahrenheit: ");
    scanf("%f", &fahrenheit);

    // Calculations (no selection statements)
    cf = (celsius * 9 / 5) + 32;
    fc = (fahrenheit - 32) * 5 / 9;

    printf("\nTemperature in Fahrenheit = %.2f\n", cf);
    printf("Temperature in Celsius = %.2f\n", fc);

    return 0;
  }

