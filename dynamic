#include <stdio.h>
#include <stdlib.h>

int main()
{
    int *ptr, n, i, newSize;

    printf("Enter number of elements: ");
    scanf("%d", &n);

    ptr = (int*) malloc(n * sizeof(int));

    printf("Enter %d elements:\n", n);
    for(i = 0; i < n; i++)
    {
        scanf("%d", &ptr[i]);
    }

    printf("Elements are:\n");
    for(i = 0; i < n; i++)
    {
        printf("%d ", ptr[i]);
    }

    printf("\nEnter new size of array: ");
    scanf("%d", &newSize);

    ptr = (int*) realloc(ptr, newSize * sizeof(int));

    printf("Enter %d elements:\n", newSize);
    for(i = 0; i < newSize; i++)
    {
        scanf("%d", &ptr[i]);
    }

    printf("Elements after realloc:\n");
    for(i = 0; i < newSize; i++)
    {
        printf("%d ", ptr[i]);
    }

    free(ptr);

    return 0;
}
