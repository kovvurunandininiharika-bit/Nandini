#include <stdio.h>
#include <stdlib.h>

int main()
{
    int n, i;
    int *ptr1, *ptr2;

    printf("Enter number of elements: ");
    scanf("%d", &n);

    // Memory allocation using malloc
    ptr1 = (int*) malloc(n * sizeof(int));

    printf("Enter %d elements for malloc array:\n", n);
    for(i = 0; i < n; i++)
    {
        scanf("%d", &ptr1[i]);
    }

    printf("Elements using malloc:\n");
    for(i = 0; i < n; i++)
    {
        printf("%d ", ptr1[i]);
    }

    printf("\n");

    // Memory allocation using calloc
    ptr2 = (int*) calloc(n, sizeof(int));

    printf("Enter %d elements for calloc array:\n", n);
    for(i = 0; i < n; i++)
    {
        scanf("%d", &ptr2[i]);
    }

    printf("Elements using calloc:\n");
    for(i = 0; i < n; i++)
    {
        printf("%d ", ptr2[i]);
    }

    free(ptr1);
    free(ptr2);

    return 0;
}
