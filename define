#include <stdio.h>

// Define the structure
struct Student {
    int id;
    char name[50];
    float marks;
};

int main() {
    // Declare structure variable
    struct Student s1;

    // Assign values
    s1.id = 101;
    strcpy(s1.name, "Ravi");
    s1.marks = 89.5;

    // Access and display values
    printf("Student Details:\n");
    printf("ID: %d\n", s1.id);
    printf("Name: %s\n", s1.name);
    printf("Marks: %.2f\n", s1.marks);

    return 0;
}
